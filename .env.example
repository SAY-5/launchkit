# Backend
DATABASE_URL=postgresql+psycopg2://launchkit:launchkit@localhost:5432/launchkit
JWT_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=60

# Provider seam. Use "fake" for local and CI runs (no network calls).
PROVIDER_MODE=fake
PROVIDER_API_KEY=

# Stripe (test mode). Leave blank to disable checkout locally.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
